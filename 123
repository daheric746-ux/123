local function setTab(name, navEntry)
	closeAllPopups()
	navEntry = navEntry or activeNavBtn
	if not navEntry or not navEntry.tabDefs then return end
	navEntry.activeTab = name
	for _, def in ipairs(navEntry.tabDefs) do
		local isActive = def.name == name
		tween(def.btn, { TextColor3 = isActive and theme.TEXT_MAIN or theme.TEXT_MUTED })
		if isActive then
			tween(TabIndicator, {
				Position = UDim2.new(0, def.x, 1, -2),
				Size     = UDim2.new(0, def.w, 0, 2),
			}, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out))
		end
		if def.clip then def.clip.Visible = isActive end
	end
end

