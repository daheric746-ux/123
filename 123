local function mountLiveWidget(shell, feat)
	local def = feat.widgetDef
	if not def then return end
	local wt = def.type
	local syncing = false

	local function pushToSource(value)
		if syncing then return end
		syncing = true
		if feat.setValue then pcall(feat.setValue, value) end
		syncing = false
	end

	if wt == "toggle" then
		local startState = false
		if feat.getter then local ok, val = pcall(feat.getter); if ok then startState = val end end
		local _, _, setOC = buildToggle(shell, startState, nil)
		setOC(function(v) pushToSource(v) end)

	elseif wt == "slider" then
		local cur = (feat.getter and select(2, pcall(feat.getter))) or def.default
		local _, setOC = buildSlider(shell, def.min, def.max, cur, nil, def.step)
		setOC(function(v) pushToSource(v) end)

	elseif wt == "dropdown" then
		local cur = (feat.getter and select(2, pcall(feat.getter))) or def.default
		local _, setOC = buildDropdown(shell, def.options, cur, nil)
		setOC(function(v) pushToSource(v) end)

	elseif wt == "multiselect" then
		local _, setOC = buildMultiSelect(shell, def.options, def.defaults, nil)
		setOC(function(v) pushToSource(v) end)

	elseif wt == "colorpicker" then
		local _, setOC = buildColorPicker(shell, def.default, nil)
		setOC(function(v) pushToSource(v) end)

	elseif wt == "input" then
		buildInput(shell, def.default, nil, function(v) pushToSource(v) end)

	elseif wt == "keybind" then
		buildKeybind(shell, def.default, nil, function(v) pushToSource(v) end)

	elseif wt == "button" then
		buildButton(shell, def.icon, def.iconLibrary, def.callback)

	elseif wt == "bind" then
		buildBind(shell, def.default, def.key, def.mode, nil)
	end
end

local function showSearchResults(query)
	clearSearchResults()
	local queryLower = query:lower()
	local count = 0
	for _, feat in ipairs(featureRegistry) do
		if feat.widgetDef and feat.widgetDef.type ~= "paragraph"
			and (fuzzyMatch(feat.titleLower or feat.title:lower(), queryLower)
				or fuzzyMatch(feat.descLower or feat.desc:lower(), queryLower)) then
			count += 1
			local shell = Instance.new("Frame")
			shell.Size             = UDim2.new(1, 0, 0, ROW_H)
			shell.BackgroundColor3 = theme.BG_ROW
			shell.BorderSizePixel  = 0
			shell.LayoutOrder      = count
			shell.ClipsDescendants = false
			shell.Parent           = searchResultsScroll
			corner(shell, 6)
			pad(shell, 0, 0, IS_MOBILE and 14 or 18, IS_MOBILE and 14 or 18)
			table.insert(searchResultFrames, shell)

			local tl = Instance.new("TextLabel")
			tl.Size             = UDim2.new(0.6, -10, 0, 20)
			tl.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 10 or 12)
			tl.BackgroundTransparency = 1
			tl.Text             = feat.title
			tl.TextColor3       = theme.TEXT_MAIN
			tl.TextSize         = IS_MOBILE and 14 or 15
			tl.Font             = Enum.Font.GothamBold
			tl.TextXAlignment   = Enum.TextXAlignment.Left
			tl.TextTruncate     = Enum.TextTruncate.AtEnd
			tl.ZIndex           = 2
			tl.Parent           = shell

			local dl = Instance.new("TextLabel")
			dl.Size             = UDim2.new(0.6, -10, 0, 14)
			dl.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 32 or 34)
			dl.BackgroundTransparency = 1
			dl.Text             = feat.desc
			dl.TextColor3       = theme.TEXT_MUTED
			dl.TextSize         = IS_MOBILE and 11 or 12
			dl.Font             = Enum.Font.Gotham
			dl.TextXAlignment   = Enum.TextXAlignment.Left
			dl.TextTruncate     = Enum.TextTruncate.AtEnd
			dl.ZIndex           = 2
			dl.Parent           = shell

			mountLiveWidget(shell, feat)
		end
	end

	if count == 0 then
		local noResult = Instance.new("TextLabel")
		noResult.Size             = UDim2.new(1, 0, 0, 40)
		noResult.BackgroundTransparency = 1
		noResult.Text             = 'No features match "' .. query .. '"'
		noResult.TextColor3       = theme.TEXT_MUTED
		noResult.TextSize         = 12
		noResult.Font             = Enum.Font.Gotham
		noResult.TextXAlignment   = Enum.TextXAlignment.Center
		noResult.LayoutOrder      = 1
		noResult.Parent           = searchResultsScroll
		table.insert(searchResultFrames, noResult)
	end
end

SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
	local q = SearchInput.Text

	if q == "" then
		if searchDebounce then task.cancel(searchDebounce); searchDebounce = nil end
		if searchActive then
			searchActive = false
			searchResultsClip.Visible = false
			clearSearchResults()
			if activeNavBtn then
				HeaderTitle.Text    = activeNavBtn.title    or ""
				HeaderSubtitle.Text = activeNavBtn.subtitle or ""
				if activeNavBtn.tabDefs then
					TabBar.Visible      = true
					TabsDivider.Visible = true
					setTab(activeNavBtn.activeTab or activeNavBtn.tabDefs[1].name, activeNavBtn)
				else
					if activeNavBtn.page then activeNavBtn.page.clip.Visible = true end
				end
			end
		end
		for _, entry in ipairs(navButtons) do entry.btn.Visible = true end
		return
	end

	if not searchActive then
		searchActive = true
		for _, p in ipairs(pages) do p.clip.Visible = false end
		TabBar.Visible = false
		TabsDivider.Visible = false
	end

	HeaderTitle.Text    = "Search Results"
	HeaderSubtitle.Text = 'Showing results for "' .. q .. '"'
	searchResultsClip.Visible = true

	if searchDebounce then task.cancel(searchDebounce); searchDebounce = nil end
	searchDebounce = task.delay(0.15, function()
		showSearchResults(q)
		local ql = q:lower()
		for _, entry in ipairs(navButtons) do
			entry.btn.Visible = fuzzyMatch(entry.nameLower or entry.name:lower(), ql)
		end
	end)
end)

