local activePopupClosers = {}

local function closeAllPopups()
	local snapshot = {}
	for i, f in ipairs(activePopupClosers) do snapshot[i] = f end
	activePopupClosers = {}
	for _, f in ipairs(snapshot) do pcall(f) end
end

local function registerPopup(closeFn)
	closeAllPopups()
	table.insert(activePopupClosers, closeFn)
	return function()
		for i, f in ipairs(activePopupClosers) do
			if f == closeFn then
				table.remove(activePopupClosers, i)
				break
			end
		end
	end
end

