local configRegistry = {}

local function snapshotConfig(registry)
	local data = {}
	for key, entry in pairs(registry) do
		if entry.getter then
			local ok, val = pcall(entry.getter)
			if ok then
				local t = type(val)
				if t == "boolean" or t == "number" or t == "string" then
					data[key] = { type = t, value = val }
				elseif t == "userdata" then
					local tv = typeof(val)
					if tv == "EnumItem" then
						data[key] = { type = "keycode", name = val.Name }
					elseif tv == "Color3" then
						data[key] = { type = "color", r = val.R, g = val.G, b = val.B }
					end
				elseif t == "table" then
					data[key] = { type = "table", value = val }
				end
			end
		end
	end
	return data
end

local SAVE_MODE_FILE = "sparestack_savemode.txt"
local saveMode = "auto"
do
	local ok, raw = pcall(readfile, SAVE_MODE_FILE)
	if ok and raw and (raw == "auto" or raw == "manual") then saveMode = raw end
end

local saveScheduled = false
local dirty = false
local loadingProfile = false
local dirtyListeners = {}

local function markDirty()
	if loadingProfile then return end
	if saveMode ~= "manual" then return end
	if dirty then return end
	dirty = true
	for _, fn in ipairs(dirtyListeners) do pcall(fn, true) end
end

local function clearDirty()
	if not dirty then return end
	dirty = false
	for _, fn in ipairs(dirtyListeners) do pcall(fn, false) end
end

local function saveConfig()
	if saveMode ~= "auto" then
		markDirty()
		return
	end
	if saveScheduled then return end
	saveScheduled = true
	task.delay(0.25, function()
		saveScheduled = false
		local data = snapshotConfig(configRegistry)
		pcall(writefile, CONFIG_KEY .. ".json", HttpService:JSONEncode(data))
	end)
end

local function forceSaveConfig()
	local data = snapshotConfig(configRegistry)
	pcall(writefile, CONFIG_KEY .. ".json", HttpService:JSONEncode(data))
end

local function persistSaveMode()
	pcall(writefile, SAVE_MODE_FILE, saveMode)
end

local function loadConfig()
	local ok, raw = pcall(readfile, CONFIG_KEY .. ".json")
	if not ok or not raw then return {} end
	local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
	return (ok2 and data) or {}
end

local function loadProfiles()
	local ok, raw = pcall(readfile, PROFILES_KEY .. ".json")
	if not ok or not raw then return {} end
	local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
	return (ok2 and data) or {}
end

local function saveProfiles(profiles)
	pcall(writefile, PROFILES_KEY .. ".json", HttpService:JSONEncode(profiles))
end

