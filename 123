	toggleBtn.BackgroundTransparency = mode == "toggle" and 0 or 1
	toggleBtn.Text = "Toggle"
	toggleBtn.TextColor3 = mode == "toggle" and Color3.fromRGB(255,255,255) or theme.TEXT_MUTED
