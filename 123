	local keySaved   = savedConfig[configKey and (configKey .. "_key")]
	local modeSaved  = savedConfig[configKey and (configKey .. "_mode")]

	local state = (stateSaved and stateSaved.type == "boolean") and stateSaved.value or (defaultOn or false)
	local currentKey = defaultKey or Enum.KeyCode.E
	if keySaved and keySaved.type == "keycode" then
		local ok, kc = pcall(function() return Enum.KeyCode[keySaved.name] end)
		if ok and kc then currentKey = kc end
	end
	local mode = defaultMode or "toggle"
	if modeSaved and modeSaved.type == "string" then mode = modeSaved.value end

	local listening = false
	local popupOpen = false
	local onChange = nil
	local trackConn
	local holdConn

	local gearBtn = Instance.new("ImageButton")
	gearBtn.Size = UDim2.new(0, 20, 0, 20)
