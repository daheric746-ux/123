function Lib:AddPage(navText, iconName, order, titleText, subtitleText, iconLibrary, hasTabs)
	local pageClip, pageScroll = makeScrollPage(hasTabs and 110 or 66)
	local pageEntry = { clip = pageClip }
	table.insert(pages, pageEntry)

	local b = Instance.new("TextButton")
	b.Size             = UDim2.new(1, 0, 0, 34)
	b.BackgroundColor3 = theme.BG_SIDEBAR
	b.BackgroundTransparency = 1
	b.Text             = ""
	b.LayoutOrder      = order
	b.Parent           = NavScroll
	corner(b, 5)

	local ico = Instance.new("ImageLabel")
	ico.Size               = UDim2.new(0, 20, 0, 20)
	ico.Position           = UDim2.new(0, 10, 0.5, -10)
	ico.BackgroundTransparency = 1
	ico.Image              = getIcon(iconName, iconLibrary or "Material")
	ico.ImageColor3        = theme.TEXT_MUTED
	ico.Parent             = b

	local lbl = Instance.new("TextLabel")
	lbl.Size             = UDim2.new(1, -38, 1, 0)
	lbl.Position         = UDim2.new(0, 38, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text             = tostring(navText)
	lbl.TextColor3       = theme.TEXT_MUTED
