local function isPointerMove(input)
	return input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch
end
local function isPointerDownEnd(input)
	return input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch
end

table.insert(globalConns, UserInputService.InputChanged:Connect(function(input)
	if not isPointerMove(input) then return end
	local x, y = input.Position.X, input.Position.Y
	for _, fn in ipairs(moveListeners) do fn(x, y) end
end))

table.insert(globalConns, UserInputService.InputEnded:Connect(function(input)
	if isPointerDownEnd(input) then
		for _, fn in ipairs(endListeners) do fn() end
	end
end))

table.insert(globalConns, UserInputService.InputBegan:Connect(function(input)
	for _, fn in ipairs(beganListeners) do fn(input) end
end))

local function onPointerMove(fn) table.insert(moveListeners, fn) end
local function onPointerEnd(fn)  table.insert(endListeners, fn) end
local function onInputBegan(fn)  table.insert(beganListeners, fn) end

local viewportEntries = {}
local viewportRenderConn

local function ensureViewportLoop()
	if viewportRenderConn then return end
	viewportRenderConn = RunService.RenderStepped:Connect(function(dt)
		for i = #viewportEntries, 1, -1 do
			local v = viewportEntries[i]
			if v.meshPart and v.meshPart.Parent then
				v.meshPart.CFrame = v.meshPart.CFrame * CFrame.Angles(0, math.rad(v.rotSpeed) * dt, 0)
			else
				table.remove(viewportEntries, i)
			end
		end
	end)
end

