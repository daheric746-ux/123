	lbl.Font             = Enum.Font.Gotham
	lbl.TextXAlignment   = Enum.TextXAlignment.Left
	lbl.TextTruncate     = Enum.TextTruncate.AtEnd
	lbl.Parent           = b

	local navEntry = {
		btn      = b,
		lbl      = lbl,
		ico      = ico,
		name     = tostring(navText),
		nameLower = tostring(navText):lower(),
		title    = tostring(titleText),
		subtitle = tostring(subtitleText),
		page     = pageEntry,
	}
	table.insert(navButtons, navEntry)
	b.MouseButton1Click:Connect(function() setActiveNav(navEntry) end)

	local Section = {}
	Section._navEntry  = navEntry
	Section._pageEntry = pageEntry
	Section._scroll    = pageScroll
	Section._rowOrder  = 0
	Section._tabClips  = nil

	function Section:_getScroll(tabName)
		if tabName and Section._tabClips and Section._tabClips[tabName] then
			return Section._tabClips[tabName].scroll
		end
		return Section._scroll
	end

	function Section:_ensureGridMode(scroll)
		if scroll:FindFirstChild("_isGrid") then return end
		local list = scroll:FindFirstChildOfClass("UIListLayout")
		if list then list:Destroy() end
		local grid = Instance.new("UIGridLayout")
		grid.SortOrder = Enum.SortOrder.LayoutOrder
		grid.CellSize  = UDim2.new(0, 160, 0, 200)
		grid.CellPadding = UDim2.new(0, 10, 0, 10)
		grid.HorizontalAlignment = Enum.HorizontalAlignment.Left
		grid.Parent    = scroll
		local marker = Instance.new("BoolValue")
		marker.Name   = "_isGrid"
		marker.Parent = scroll
	end

	function Section:AddTabBar(tabNames)
		Section._tabClips = {}
		navEntry.tabDefs  = {}
		navEntry.activeTab = tabNames[1]
		for i, tName in ipairs(tabNames) do
			local tabClip2, tabScroll2 = makeScrollPage(110)
			table.insert(pages, { clip = tabClip2 })
			Section._tabClips[tName] = { clip = tabClip2, scroll = tabScroll2 }

			local tw = #tName * (IS_MOBILE and 7 or 8) + 10
			local tabBtn = Instance.new("TextButton")
			tabBtn.Size             = UDim2.new(0, tw, 1, 0)
			tabBtn.BackgroundTransparency = 1
			tabBtn.Text             = tName
			tabBtn.TextColor3       = i == 1 and theme.TEXT_MAIN or theme.TEXT_MUTED
			tabBtn.TextSize         = IS_MOBILE and 13 or 14
			tabBtn.Font             = Enum.Font.GothamBold

			local def = { name = tName, btn = tabBtn, w = tw, clip = tabClip2, x = 0 }
			table.insert(navEntry.tabDefs, def)
			tabBtn.MouseButton1Click:Connect(function() setTab(tName, navEntry) end)
		end
		return Section._tabClips
	end

	function Section:AddRow(titleText2, descText2, widgetDef2, tabName2)
		Section._rowOrder += 1
		local scroll = Section:_getScroll(tabName2)
		return buildRow(scroll, titleText2, descText2, Section._rowOrder, widgetDef2, pageEntry, navEntry, tabName2)
	end

	function Section:AddParagraph(titleText2, body, tabName2)
		Section._rowOrder += 1
		local scroll = Section:_getScroll(tabName2)
		return buildRow(scroll, titleText2, "", Section._rowOrder, { type = "paragraph", text = body }, pageEntry, navEntry, tabName2)
	end

	function Section:AddViewport(name, meshId, textureId, applyCallback, tabName2, tooltip)
		local scroll = Section:_getScroll(tabName2)
		Section:_ensureGridMode(scroll)
		Section._rowOrder += 1
		return buildViewportCard(scroll, name, meshId, textureId, applyCallback, Section._rowOrder, tooltip)
	end

	function Section:AddGroup(groupName, tabName2)
		Section._rowOrder += 1
		local scroll = Section:_getScroll(tabName2)

		local groupFrame = Instance.new("Frame")
		groupFrame.Size             = UDim2.new(1, 0, 0, 0)
		groupFrame.AutomaticSize    = Enum.AutomaticSize.Y
		groupFrame.BackgroundTransparency = 1
		groupFrame.LayoutOrder      = Section._rowOrder
		groupFrame.Parent           = scroll

		local groupLayout = Instance.new("UIListLayout")
		groupLayout.SortOrder = Enum.SortOrder.LayoutOrder
		groupLayout.Padding   = UDim.new(0, 4)
		groupLayout.Parent    = groupFrame

		local header = Instance.new("TextLabel")
		header.Size             = UDim2.new(1, 0, 0, 22)
		header.BackgroundTransparency = 1
		header.Text             = string.upper(tostring(groupName))
		header.TextColor3       = theme.TEXT_MUTED
		header.TextSize         = 11
		header.Font             = Enum.Font.GothamBold
		header.TextXAlignment   = Enum.TextXAlignment.Left
		header.LayoutOrder      = 1
		header.Parent           = groupFrame

		local container = Instance.new("Frame")
		container.Size             = UDim2.new(1, 0, 0, 0)
		container.AutomaticSize    = Enum.AutomaticSize.Y
		container.BackgroundTransparency = 1
		container.LayoutOrder      = 2
		container.Parent           = groupFrame

		local layout = Instance.new("UIListLayout")
		layout.SortOrder = Enum.SortOrder.LayoutOrder
		layout.Padding   = UDim.new(0, 8)
		layout.Parent    = container

		local Group = {}
		Group._rowOrder = 0

		function Group:AddRow(t, d, w)
			Group._rowOrder += 1
			return buildRow(container, t, d, Group._rowOrder, w, pageEntry, navEntry, tabName2)
		end
		function Group:AddParagraph(t, body)
			Group._rowOrder += 1
			return buildRow(container, t, "", Group._rowOrder, { type = "paragraph", text = body }, pageEntry, navEntry, tabName2)
		end

		return Group
	end

	return Section
end

function Lib:SaveProfile(name)
	if not name or name == "" then return false end
	local profiles = loadProfiles()
	profiles[name] = snapshotConfig(configRegistry)
	saveProfiles(profiles)
	clearDirty()
	return true
end

function Lib:LoadProfile(name)
	local profiles = loadProfiles()
	local data = profiles[name]
	if not data then return false end
	loadingProfile = true
	for key, entry in pairs(data) do
		local feat
		for _, f in ipairs(featureRegistry) do
			if f.configKey == key then feat = f; break end
		end
		if feat and feat.setValue then
			if entry.type == "color" then
				pcall(feat.setValue, Color3.new(entry.r, entry.g, entry.b))
			elseif entry.type == "keycode" then
				local ok, kc = pcall(function() return Enum.KeyCode[entry.name] end)
				if ok and kc then pcall(feat.setValue, kc) end
			elseif entry.type == "table" then
				pcall(feat.setValue, entry.value)
			else
				pcall(feat.setValue, entry.value)
			end
		end
	end
	loadingProfile = false
	clearDirty()
	saveConfig()
	return true
end

function Lib:DeleteProfile(name)
	local profiles = loadProfiles()
	profiles[name] = nil
	saveProfiles(profiles)
end

function Lib:ListProfiles()
	local profiles = loadProfiles()
	local out = {}
	for name in pairs(profiles) do table.insert(out, name) end
	table.sort(out)
	return out
end

function Lib:Destroy()
	for _, conn in ipairs(globalConns) do pcall(function() conn:Disconnect() end) end
	globalConns = {}
	if viewportRenderConn then viewportRenderConn:Disconnect(); viewportRenderConn = nil end
	viewportEntries = {}
	moveListeners, endListeners, beganListeners = {}, {}, {}
	pcall(function() ContextActionService:UnbindAction("SpareStackToggle") end)
	if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
end

function Lib:Init(defaultNavEntry, defaultTabName, keybindCode)
	currentKeybind = keybindCode or Enum.KeyCode.RightShift

	setActiveNav(defaultNavEntry or navButtons[1])
	if defaultTabName then setTab(defaultTabName) end

	if not IS_MOBILE then
		ContextActionService:BindActionAtPriority(
			"SpareStackToggle",
			function(_, inputState)
				if inputState == Enum.UserInputState.Begin then
					MainFrame.Visible = not MainFrame.Visible
				end
				return Enum.ContextActionResult.Pass
			end,
			false, 2001, currentKeybind
		)
	end

	if IS_MOBILE then
		local fab = Instance.new("TextButton")
		fab.Name               = "SpareStackFAB"
		fab.Size               = UDim2.new(0, 50, 0, 50)
		fab.Position           = UDim2.new(0, 14, 0.5, -25)
		fab.BackgroundColor3   = theme.BG_SIDEBAR
		fab.Text               = ""
		fab.AutoButtonColor    = false
		fab.ZIndex             = 50
		fab.Parent             = ScreenGui
		corner(fab, 25)

		local fabStroke = Instance.new("UIStroke")
		fabStroke.Color     = theme.ACCENT
		fabStroke.Thickness = 1.5
		fabStroke.Parent    = fab

		local fabIco = Instance.new("ImageLabel")
		fabIco.Size               = UDim2.new(0, 24, 0, 24)
		fabIco.Position           = UDim2.new(0.5, -12, 0.5, -12)
		fabIco.BackgroundTransparency = 1
		fabIco.Image              = getIcon("menu")
		fabIco.ImageColor3        = theme.ACCENT
		fabIco.Parent             = fab

		local fabDragging, fabStart, fabStartPos = false, nil, nil
		local moved = false
		fab.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.Touch
				or input.UserInputType == Enum.UserInputType.MouseButton1 then
				fabDragging = true; moved = false
				fabStart = input.Position
				fabStartPos = fab.Position
			end
		end)
		onPointerMove(function(x, y)
			if not fabDragging then return end
			local dx = x - fabStart.X
			local dy = y - fabStart.Y
			if math.abs(dx) > 4 or math.abs(dy) > 4 then moved = true end
			fab.Position = UDim2.new(
				fabStartPos.X.Scale, fabStartPos.X.Offset + dx,
				fabStartPos.Y.Scale, fabStartPos.Y.Offset + dy
			)
		end)
		onPointerEnd(function()
			if fabDragging and not moved then
				MainFrame.Visible = not MainFrame.Visible
			end
			fabDragging = false
		end)
	end

	task.delay(0.5, function()
		showNotif("Welcome back", "spare stack loaded successfully.", "success")
	end)
end

