	chevron.ZIndex             = 4
	chevron.Parent             = frame

	local clickBtn = Instance.new("TextButton")
	clickBtn.Size                = UDim2.new(1, 0, 1, 0)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Text                = ""
	clickBtn.ZIndex              = 5
	clickBtn.Parent              = frame

	local listClip = Instance.new("Frame")
	listClip.Size             = UDim2.new(0, W_WIDE, 0, 0)
	listClip.BackgroundTransparency = 1
	listClip.BorderSizePixel  = 0
	listClip.ClipsDescendants = true
	listClip.ZIndex           = 9
	listClip.Parent           = MainFrame

	local listBg = Instance.new("Frame")
	listBg.Size             = UDim2.new(1, 0, 0, openH)
	listBg.BackgroundColor3 = Color3.fromRGB(22, 21, 32)
	listBg.BorderSizePixel  = 0
	listBg.ZIndex           = 10
	listBg.Parent           = listClip
	corner(listBg, 6)

	local ll = Instance.new("UIListLayout")
	ll.SortOrder = Enum.SortOrder.LayoutOrder
	ll.Padding   = UDim.new(0, 0)
	ll.Parent    = listBg
	pad(listBg, 4, 4, 0, 0)

	local itemBtns = {}

	local function refreshColors()
		for _, e in ipairs(itemBtns) do
			tween(e.btn, { BackgroundColor3 = e.opt == selected and Color3.fromRGB(30,28,44) or Color3.fromRGB(22,21,32) }, TI_FAST)
			e.lbl.TextColor3 = e.opt == selected and theme.TEXT_MAIN or theme.TEXT_MUTED
		end
	end

	local function positionList()
		local ap  = frame.AbsolutePosition
		local fp  = MainFrame.AbsolutePosition
		listClip.Position = UDim2.new(0, ap.X - fp.X, 0, ap.Y - fp.Y + 38)
	end

	local unregister

	local function closeList()
		open = false
		tween(listClip, { Size = UDim2.new(0, W_WIDE, 0, 0) })
		tween(chevron,  { Rotation = 0 }, TI_NORM)
		tween(frame,    { BackgroundColor3 = theme.BG_INPUT }, TI_FAST)
		if trackConn then trackConn:Disconnect(); trackConn = nil end
		if unregister then unregister(); unregister = nil end
	end

	local function setValue(v, silent)
		if not v then return end
		selected = v
		label.Text = v
		refreshColors()
		if configKey then saveConfig() end
		if onChange and not silent then onChange(selected) end
	end

	local function buildOneItem(i, opt)
		local item = Instance.new("TextButton")
		item.Size             = UDim2.new(1, 0, 0, ITEM_H)
		item.BackgroundColor3 = opt == selected and Color3.fromRGB(30,28,44) or Color3.fromRGB(22,21,32)
		item.BackgroundTransparency = 0
		item.Text             = ""
		item.LayoutOrder      = i
		item.ZIndex           = 11
		item.Parent           = listBg
		corner(item, 4)

		local itemLbl = Instance.new("TextLabel")
		itemLbl.Size             = UDim2.new(1, -20, 1, 0)
		itemLbl.Position         = UDim2.new(0, 12, 0, 0)
		itemLbl.BackgroundTransparency = 1
		itemLbl.Text             = opt
		itemLbl.TextColor3       = opt == selected and theme.TEXT_MAIN or theme.TEXT_MUTED
		itemLbl.TextSize         = 13
		itemLbl.Font             = Enum.Font.Gotham
		itemLbl.TextXAlignment   = Enum.TextXAlignment.Left
		itemLbl.ZIndex           = 12
		itemLbl.Parent           = item

		table.insert(itemBtns, { btn = item, lbl = itemLbl, opt = opt })

		item.MouseEnter:Connect(function()
			if opt ~= selected then tween(item, { BackgroundColor3 = Color3.fromRGB(26,25,38) }, TI_FAST) end
		end)
		item.MouseLeave:Connect(function()
			if opt ~= selected then tween(item, { BackgroundColor3 = Color3.fromRGB(22,21,32) }, TI_FAST) end
		end)
		item.MouseButton1Click:Connect(function()
			setValue(opt)
			closeList()
		end)
	end

	for i, opt in ipairs(options) do
		buildOneItem(i, opt)
	end

	local function setOptions(newList)
		if type(newList) ~= "table" then return end
		options = newList
		for _, e in ipairs(itemBtns) do e.btn:Destroy() end
		itemBtns = {}
		local stillValid = false
		for _, o in ipairs(newList) do if o == selected then stillValid = true; break end end
		if not stillValid then
			selected = newList[1]
			label.Text = selected or ""
		end
		openH = #newList * ITEM_H + 8
		for i, opt in ipairs(newList) do buildOneItem(i, opt) end
		if open then
			tween(listClip, { Size = UDim2.new(0, W_WIDE, 0, openH) })
		end
	end

	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		if open then
			positionList()
			tween(listClip, { Size = UDim2.new(0, W_WIDE, 0, openH) })
			tween(chevron,  { Rotation = 180 }, TI_NORM)
			tween(frame,    { BackgroundColor3 = Color3.fromRGB(24,23,34) }, TI_FAST)
			trackConn = RunService.RenderStepped:Connect(function()
				positionList()
				if not frame or not frame.Parent then
					if trackConn then trackConn:Disconnect(); trackConn = nil end
				end
			end)
			unregister = registerPopup(closeList)
		else
			closeList()
		end
	end)

	return function() return selected end,
		function(fn) onChange = fn end,
		setValue,
		setOptions
end

local function buildKeybind(parent, default, configKey, onChanged)
	local saved = savedConfig[configKey]
	local currentKey = default or Enum.KeyCode.RightShift
	if saved and saved.type == "keycode" then
		local ok, kc = pcall(function() return Enum.KeyCode[saved.name] end)
		if ok and kc then currentKey = kc end
	end

	local listening = false

	local btn = Instance.new("TextButton")
	btn.Size             = UDim2.new(0, IS_MOBILE and 110 or 125, 0, 34)
	btn.Position         = UDim2.new(1, IS_MOBILE and -110 or -125, 0.5, -17)
	btn.BackgroundColor3 = theme.BG_INPUT
	btn.Text             = IS_MOBILE and "N/A (mobile)" or currentKey.Name
	btn.TextColor3       = IS_MOBILE and theme.TEXT_MUTED or theme.TEXT_MAIN
	btn.TextSize         = 12
	btn.Font             = Enum.Font.Gotham
	btn.ZIndex           = 3
	btn.Parent           = parent
	corner(btn, 5)

	local function setValue(kc, silent)
		if typeof(kc) ~= "EnumItem" then return end
		currentKey = kc
		btn.Text = currentKey.Name
		if configKey then saveConfig() end
		if onChanged and not silent then onChanged(currentKey) end
	end

	if not IS_MOBILE then
		btn.MouseButton1Click:Connect(function()
			if listening then return end
			listening = true
			btn.Text = "Press a key..."
			tween(btn, { BackgroundColor3 = Color3.fromRGB(25,22,40) }, TI_FAST)
			tween(btn, { TextColor3 = theme.ACCENT })
		end)

		onInputBegan(function(input)
			if not listening then return end
			if input.UserInputType == Enum.UserInputType.Keyboard then
				if input.KeyCode == Enum.KeyCode.Escape then
					listening = false
					btn.Text = currentKey.Name
					tween(btn, { TextColor3 = theme.TEXT_MAIN })
					tween(btn, { BackgroundColor3 = theme.BG_INPUT }, TI_FAST)
					return
				end
				setValue(input.KeyCode)
				tween(btn, { TextColor3 = theme.TEXT_MAIN })
				tween(btn, { BackgroundColor3 = theme.BG_INPUT }, TI_FAST)
				listening = false
			end
		end)
	end

	return function() return currentKey end,
		function(fn) onChanged = fn end,
		setValue
end

