local function showNotif(title, message, notifType)
	if not notifEnabled then return end
	notifCount += 1

	while #activeNotifs >= MAX_NOTIFS do
		local oldest = table.remove(activeNotifs, 1)
		if oldest and oldest.dismiss then oldest.dismiss() end
	end

	local typeColor = theme.ACCENT
	if notifType == "success" then typeColor = Color3.fromRGB(60, 200, 120)
	elseif notifType == "error" then typeColor = Color3.fromRGB(220, 70, 70)
	elseif notifType == "warning" then typeColor = Color3.fromRGB(220, 160, 40) end

	local card = Instance.new("Frame")
	card.Name              = "Notif_" .. notifCount
	card.Size              = UDim2.new(1, 0, 0, 52)
	card.BackgroundColor3  = Color3.fromRGB(18, 17, 27)
	card.BorderSizePixel   = 0
	card.LayoutOrder       = notifCount
	card.ZIndex            = 999
	card.ClipsDescendants  = true
	card.Parent            = notifHolder
	corner(card, 7)

	local stroke = Instance.new("UIStroke")
	stroke.Color     = Color3.fromRGB(32, 30, 48)
	stroke.Thickness = 1
	stroke.Parent    = card

	local function makeLabel(sz, pos, txt, col, size, font, xAlign)
		local l = Instance.new("TextLabel")
		l.Size                = sz
		l.Position            = pos
		l.BackgroundTransparency = 1
		l.Text                = txt
		l.TextColor3          = col
		l.TextSize            = size
		l.Font                = font
		l.TextXAlignment      = xAlign or Enum.TextXAlignment.Left
		l.ZIndex              = 1000
		l.Parent              = card
		return l
	end

	local titleLbl = makeLabel(UDim2.new(1,-36,0,16), UDim2.new(0,12,0,9),  tostring(title),   theme.TEXT_MAIN,  12, Enum.Font.GothamBold)
	local msgLbl   = makeLabel(UDim2.new(1,-36,0,13), UDim2.new(0,12,0,27), tostring(message), theme.TEXT_MUTED, 10, Enum.Font.Gotham)

	local closeBtn = Instance.new("TextButton")
	closeBtn.Size                = UDim2.new(0, 18, 0, 18)
	closeBtn.Position            = UDim2.new(1, -24, 0, 5)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Text                = "×"
	closeBtn.TextColor3          = theme.TEXT_MUTED
	closeBtn.TextSize            = 15
	closeBtn.Font                = Enum.Font.GothamBold
	closeBtn.ZIndex              = 1001
	closeBtn.Parent              = card

	local progress = Instance.new("Frame")
	progress.Size             = UDim2.new(1, -24, 0, 2)
	progress.Position         = UDim2.new(0, 12, 1, -4)
	progress.BackgroundColor3 = typeColor
	progress.BackgroundTransparency = 0.3
	progress.BorderSizePixel  = 0
	progress.ZIndex           = 1000
	progress.Parent           = card
	corner(progress, 1)
	tween(progress, { Size = UDim2.new(0, 0, 0, 2) }, TweenInfo.new(4, Enum.EasingStyle.Linear))

	local dismissed = false
	local entry = {}
	local function dismiss()
		if dismissed then return end
		dismissed = true
		for i, e in ipairs(activeNotifs) do
			if e == entry then table.remove(activeNotifs, i); break end
		end
		local ti = TweenInfo.new(0.2, Enum.EasingStyle.Quad)
		tween(card,     { BackgroundTransparency = 1 }, ti)
		tween(titleLbl, { TextTransparency = 1 },       ti)
		tween(msgLbl,   { TextTransparency = 1 },       ti)
		tween(stroke,   { Transparency = 1 },           ti)
		task.delay(0.22, function()
			tween(card, { Size = UDim2.new(1, 0, 0, 0) }, TI_FAST)
			task.delay(0.14, function() if card and card.Parent then card:Destroy() end end)
		end)
	end
	entry.dismiss = dismiss
	table.insert(activeNotifs, entry)

	closeBtn.MouseButton1Click:Connect(dismiss)
	task.delay(4.1, function() if card and card.Parent then dismiss() end end)
end

