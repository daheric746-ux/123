local function buildRow(parent, titleText, descText, order, widgetDef, pageEntry, navEntry, tabName)
	if widgetDef and widgetDef.type == "paragraph" then
		local card = buildParagraph(parent, titleText, widgetDef.text or descText or "", order)
		table.insert(featureRegistry, {
			title = tostring(titleText or "Info"),
			desc  = tostring(widgetDef.text or descText or ""),
			row   = card,
			widgetDef = widgetDef,
			page = pageEntry, navEntry = navEntry, tabName = tabName,
			getter = function() return widgetDef.text or "" end,
		})
		if widgetDef.tooltip then attachTooltip(card, widgetDef.tooltip) end
		return card
	end

	local row = Instance.new("Frame")
	row.Size             = UDim2.new(1, 0, 0, ROW_H)
	row.BackgroundColor3 = theme.BG_ROW
	row.BorderSizePixel  = 0
	row.LayoutOrder      = order
	row.ClipsDescendants = false
	row.Parent           = parent
	corner(row, 6)
	pad(row, 0, 0, IS_MOBILE and 14 or 18, IS_MOBILE and 14 or 18)

	local title = Instance.new("TextLabel")
	title.Size             = UDim2.new(0.5, -10, 0, 20)
	title.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 10 or 12)
	title.BackgroundTransparency = 1
	title.Text             = tostring(titleText)
	title.TextColor3       = theme.TEXT_MAIN
	title.TextSize         = IS_MOBILE and 14 or 15
	title.Font             = Enum.Font.GothamBold
	title.TextXAlignment   = Enum.TextXAlignment.Left
	title.TextTruncate     = Enum.TextTruncate.AtEnd
	title.ZIndex           = 2
	title.Parent           = row

	local desc = Instance.new("TextLabel")
	desc.Size             = UDim2.new(0.5, -10, 0, 14)
	desc.Position         = UDim2.new(0, 0, 0, IS_MOBILE and 32 or 34)
	desc.BackgroundTransparency = 1
	desc.Text             = tostring(descText)
	desc.TextColor3       = theme.TEXT_MUTED
	desc.TextSize         = IS_MOBILE and 11 or 12
	desc.Font             = Enum.Font.Gotham
	desc.TextXAlignment   = Enum.TextXAlignment.Left
	desc.TextTruncate     = Enum.TextTruncate.AtEnd
	desc.ZIndex           = 2
	desc.Parent           = row

	local hoverZone = Instance.new("TextButton")
	hoverZone.Size                = UDim2.new(0.5, -10, 1, 0)
	hoverZone.BackgroundTransparency = 1
	hoverZone.Text                = ""
	hoverZone.ZIndex              = 1
	hoverZone.Parent              = row

	hoverZone.MouseEnter:Connect(function() tween(row, { BackgroundColor3 = Color3.fromRGB(18,17,26) }, TI_FAST) end)
	hoverZone.MouseLeave:Connect(function() tween(row, { BackgroundColor3 = theme.BG_ROW }, TI_FAST) end)

	local configKey = (navEntry and navEntry.name or "") .. "_" .. tostring(titleText)

	local getter, setOnChange, setValue
	local setOptions
	local toggleFn, toggleSetState
	local bindKeyGetter
	local wt = widgetDef and widgetDef.type

	if wt == "toggle" then
		local g, fn, oc, setS = buildToggle(row, widgetDef.default, configKey)
		getter, toggleFn, setOnChange, toggleSetState = g, fn, oc, setS
		setValue = setS

	elseif wt == "slider" then
		local step = widgetDef.step
		if widgetDef.decimals then
			local d = math.clamp(math.floor(widgetDef.decimals), 0, 3)
			step = 10 ^ (-d)
		end
		local g, oc, sv = buildSlider(row, widgetDef.min, widgetDef.max, widgetDef.default, configKey, step)
		getter, setOnChange, setValue = g, oc, sv

	elseif wt == "dropdown" then
		local g, oc, sv, so = buildDropdown(row, widgetDef.options, widgetDef.default, configKey)
		getter, setOnChange, setValue = g, oc, sv
		setOptions = so

	elseif wt == "keybind" then
		local g, oc, sv = buildKeybind(row, widgetDef.default, configKey, widgetDef.onChange)
		getter, setOnChange, setValue = g, oc, sv

	elseif wt == "input" then
		local _, g, oc, sv = buildInput(row, widgetDef.default, configKey, widgetDef.onChange)
		getter, setOnChange, setValue = g, oc, sv

	elseif wt == "button" then
		getter = buildButton(row, widgetDef.icon, widgetDef.iconLibrary, widgetDef.callback)

	elseif wt == "colorpicker" then
		local g, oc, sv = buildColorPicker(row, widgetDef.default, configKey)
		getter, setOnChange, setValue = g, oc, sv

	elseif wt == "multiselect" then
		local g, oc, sv = buildMultiSelect(row, widgetDef.options, widgetDef.defaults, configKey)
		getter, setOnChange, setValue = g, oc, sv

	elseif wt == "bind" then
		local g, oc, sv, gk = buildBind(row, widgetDef.default, widgetDef.key, widgetDef.mode, configKey)
		getter, setOnChange, setValue = g, oc, sv
		bindKeyGetter = gk
	end

	if wt == "toggle" and toggleFn then
		hoverZone.Size = UDim2.new(1, 0, 1, 0)
		hoverZone.MouseButton1Click:Connect(toggleFn)
	elseif wt == "bind" and setValue and getter then
		hoverZone.Size = UDim2.new(1, 0, 1, 0)
		hoverZone.MouseButton1Click:Connect(function()
			setValue(not getter())
		end)
	end

	if getter and configKey and wt ~= "button" then
		configRegistry[configKey] = { getter = getter }
	end

	if widgetDef and widgetDef.onChange and setOnChange then
		setOnChange(widgetDef.onChange)
		task.defer(function()
			local ok, val = pcall(getter)
			if ok and val ~= nil then
				pcall(widgetDef.onChange, val)
			end
		end)
	end

	local feat = {
		title          = tostring(titleText),
		desc           = tostring(descText),
		titleLower     = tostring(titleText):lower(),
		descLower      = tostring(descText):lower(),
		row            = row,
		widgetDef      = widgetDef,
		page           = pageEntry,
		navEntry       = navEntry,
		tabName        = tabName,
		configKey      = configKey,
		getter         = getter,
		setOnChange    = setOnChange,
		setValue       = setValue,
		toggleFn       = toggleFn,
		toggleSetState = toggleSetState,
		bindKeyGetter  = bindKeyGetter,
	}
	table.insert(featureRegistry, feat)

	if widgetDef and widgetDef.tooltip then
		attachTooltip(hoverZone, widgetDef.tooltip)
	end

	if widgetDef and widgetDef.disabled then
		row.BackgroundTransparency = 0.5
		title.TextTransparency = 0.5
		desc.TextTransparency = 0.5
		hoverZone.Active = false
	end

	local rowObj = {
		_row = row, _title = title, _desc = desc, _hover = hoverZone,
		_feat = feat,
	}
	function rowObj:SetDisabled(d)
		if d then
			row.BackgroundTransparency = 0.5
			title.TextTransparency = 0.5
			desc.TextTransparency = 0.5
			hoverZone.Active = false
		else
			row.BackgroundTransparency = 0
			title.TextTransparency = 0
			desc.TextTransparency = 0
			hoverZone.Active = true
		end
	end
	function rowObj:Get() return getter and getter() end
	function rowObj:Set(v) if setValue then setValue(v) end end
	function rowObj:SetOptions(list) if setOptions then setOptions(list) end end
	function rowObj:SetSubtitle(text) if desc then desc.Text = tostring(text or "") end end
	function rowObj:SetTitle(text) if title then title.Text = tostring(text or "") end end

	return rowObj, getter, setValue
end

local function fuzzyMatch(str, query)
	if str:find(query, 1, true) then return true end
	local si = 1
	for qi = 1, #query do
		local qc = query:sub(qi, qi)
		local found = false
		while si <= #str do
			if str:sub(si, si) == qc then si += 1; found = true; break end
			si += 1
		end
		if not found then return false end
	end
	return true
end

