	toggleBtn.BorderSizePixel = 0
	toggleBtn.AutoButtonColor = false
	toggleBtn.ZIndex = 47
	toggleBtn.Parent = modePill
	corner(toggleBtn, 4)

	local function refreshMode()
		tween(holdBtn,   { BackgroundTransparency = mode == "hold"   and 0 or 1, TextColor3 = mode == "hold"   and Color3.fromRGB(255,255,255) or theme.TEXT_MUTED }, TI_FAST)
		tween(toggleBtn, { BackgroundTransparency = mode == "toggle" and 0 or 1, TextColor3 = mode == "toggle" and Color3.fromRGB(255,255,255) or theme.TEXT_MUTED }, TI_FAST)
	end

	local function applyVisual()
		tween(track, { BackgroundColor3 = state and theme.ACCENT or theme.BG_INPUT })
		tween(ball,  { Position = state and UDim2.new(1,-20,0.5,-8) or UDim2.new(0,4,0.5,-8) }, TI_SPRING)
	end

	local function setStateDirect(v, silent)
		if state == v then return end
		state = v
		applyVisual()
		if configKey then saveConfig() end
		if onChange and not silent then onChange(state, currentKey) end
	end

	hit.MouseButton1Click:Connect(function() setStateDirect(not state) end)

	local function bindHoldRelease()
		if holdConn then holdConn:Disconnect(); holdConn = nil end
		if mode == "hold" and not IS_MOBILE then
			holdConn = UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.Keyboard
					and input.KeyCode == currentKey then
					setStateDirect(false)
				end
			end)
			table.insert(globalConns, holdConn)
		end
	end

	local function setMode(m)
		if mode == m then return end
		mode = m
		refreshMode()
		if configKey then saveConfig() end
		bindHoldRelease()
	end

	holdBtn.MouseButton1Click:Connect(function() setMode("hold") end)
	toggleBtn.MouseButton1Click:Connect(function() setMode("toggle") end)

	local function positionPopup()
		local ap = gearBtn.AbsolutePosition
		local fp = MainFrame.AbsolutePosition
		local x = ap.X - fp.X + gearBtn.AbsoluteSize.X - POPUP_W
		local y = ap.Y - fp.Y + gearBtn.AbsoluteSize.Y + 6
		if y + POPUP_H > MainFrame.AbsoluteSize.Y then
			y = ap.Y - fp.Y - POPUP_H - 6
		end
		popup.Position = UDim2.new(0, x, 0, y)
	end

	local unregisterBind

	local function closePopup()
		popupOpen = false
		popup.Visible = false
		tween(gearBtn, { ImageColor3 = theme.TEXT_MUTED }, TI_FAST)
		if trackConn then trackConn:Disconnect(); trackConn = nil end
		if unregisterBind then unregisterBind(); unregisterBind = nil end
	end

	gearBtn.MouseButton1Click:Connect(function()
		popupOpen = not popupOpen
		if popupOpen then
			positionPopup()
			popup.Visible = true
			tween(gearBtn, { ImageColor3 = theme.ACCENT }, TI_FAST)
			trackConn = RunService.RenderStepped:Connect(function()
				positionPopup()
				if not gearBtn or not gearBtn.Parent then
					if trackConn then trackConn:Disconnect(); trackConn = nil end
				end
			end)
			unregisterBind = registerPopup(closePopup)
		else
			closePopup()
		end
	end)

	gearBtn.MouseEnter:Connect(function()
		if not popupOpen then tween(gearBtn, { ImageColor3 = theme.TEXT_MAIN }, TI_FAST) end
	end)
	gearBtn.MouseLeave:Connect(function()
		if not popupOpen then tween(gearBtn, { ImageColor3 = theme.TEXT_MUTED }, TI_FAST) end
	end)

	if not IS_MOBILE then
		keyBtn.MouseButton1Click:Connect(function()
			if listening then return end
			listening = true
			keyBtn.Text = "Press a key..."
			tween(keyBtn, { BackgroundColor3 = Color3.fromRGB(25,22,40), TextColor3 = theme.ACCENT }, TI_FAST)
		end)
	end

	onInputBegan(function(input)
		if listening and input.UserInputType == Enum.UserInputType.Keyboard then
			if input.KeyCode == Enum.KeyCode.Escape then
				listening = false
				keyBtn.Text = currentKey.Name
				tween(keyBtn, { BackgroundColor3 = theme.BG_INPUT, TextColor3 = theme.TEXT_MAIN }, TI_FAST)
				return
			end
			currentKey = input.KeyCode
			keyBtn.Text = currentKey.Name
			tween(keyBtn, { BackgroundColor3 = theme.BG_INPUT, TextColor3 = theme.TEXT_MAIN }, TI_FAST)
			listening = false
			if configKey then saveConfig() end
			bindHoldRelease()
			return
		end

		if input.UserInputType == Enum.UserInputType.Keyboard
			and input.KeyCode == currentKey
			and not UserInputService:GetFocusedTextBox() then
			if mode == "toggle" then
				setStateDirect(not state)
			elseif mode == "hold" then
				setStateDirect(true)
			end
		end
	end)

	onInputBegan(function(input)
		if not popupOpen then return end
		if isPointerDownEnd(input) then
			task.defer(function()
				if not popup.Visible then return end
				local guiInset = GuiService:GetGuiInset()
				local mp = UserInputService:GetMouseLocation()
				mp = Vector2.new(mp.X - guiInset.X, mp.Y - guiInset.Y)
				local ap, as = popup.AbsolutePosition, popup.AbsoluteSize
				local gp, gs = gearBtn.AbsolutePosition, gearBtn.AbsoluteSize
				local onPopup = mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
				local onGear  = mp.X >= gp.X and mp.X <= gp.X+gs.X and mp.Y >= gp.Y and mp.Y <= gp.Y+gs.Y
				if not onPopup and not onGear then closePopup() end
			end)
		end
	end)

	bindHoldRelease()

	local function getState() return state end
	local function getKey()   return currentKey end
	local function getMode()  return mode end

	if configKey then
		configRegistry[configKey .. "_key"]  = { getter = getKey }
		configRegistry[configKey .. "_mode"] = { getter = getMode }
	end

	return getState,
		function(fn) onChange = fn end,
		function(v, silent) setStateDirect(v, silent) end,
		getKey
end

local function buildViewportCard(parent, name, meshId, textureId, applyCallback, order, tooltip)
	local card = Instance.new("Frame")
	card.Size              = UDim2.new(0, 160, 0, 200)
	card.BackgroundColor3  = theme.BG_ROW
	card.BorderSizePixel   = 0
	card.LayoutOrder       = order or 0
	card.ClipsDescendants  = true
	card.Parent            = parent
	corner(card, 8)

	local hasMesh = meshId and meshId ~= ""

	if hasMesh then
		local viewport = Instance.new("ViewportFrame")
		viewport.Size              = UDim2.new(1, -12, 0, 120)
		viewport.Position          = UDim2.new(0, 6, 0, 6)
		viewport.BackgroundColor3  = Color3.fromRGB(20, 19, 30)
		viewport.BorderSizePixel   = 0
		viewport.Parent            = card
		corner(viewport, 6)

		local world = Instance.new("WorldModel")
		world.Parent = viewport

		local camera = Instance.new("Camera")
		camera.Parent = viewport
		viewport.CurrentCamera = camera

		local model = Instance.new("Model")
		model.Name = "PreviewModel"

		local meshPart = Instance.new("MeshPart")
		meshPart.Anchored    = true
		meshPart.CanCollide  = false
		meshPart.MeshId      = meshId
		meshPart.TextureID   = textureId or ""
		meshPart.Size        = Vector3.new(4, 4, 4)
		meshPart.Parent      = model

		model.PrimaryPart = meshPart
		model.Parent      = world

		local function updateCamera()
			local size = model:GetExtentsSize()
			if size.Magnitude < 0.01 then return end
			local center = model:GetBoundingBox().Position
			local radius = size.Magnitude / 2
			local absSize = viewport.AbsoluteSize
			if absSize.X <= 0 or absSize.Y <= 0 then return end
			local aspect = absSize.X / absSize.Y
			local vFov = math.rad(camera.FieldOfView)
			local hFov = 2 * math.atan(math.tan(vFov / 2) * aspect)
			local fov = math.min(vFov, hFov)
			local distance = (radius / 0.85) / math.sin(fov / 2)
			camera.CFrame = CFrame.lookAt(
				center + Vector3.new(0, size.Y * 0.15, distance),
				center
			)
		end

		task.spawn(function()
			for _ = 1, 60 do
				task.wait(0.1)
				if model:GetExtentsSize().Magnitude > 0.5 then break end
			end
			updateCamera()
		end)

		viewport:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateCamera)

		table.insert(viewportEntries, { meshPart = meshPart, rotSpeed = 35 })
		ensureViewportLoop()
	else
		local img = Instance.new("ImageLabel")
		img.Size              = UDim2.new(1, -12, 0, 120)
		img.Position          = UDim2.new(0, 6, 0, 6)
		img.BackgroundColor3  = Color3.fromRGB(20, 19, 30)
		img.BorderSizePixel   = 0
		img.Image             = textureId or ""
		img.ScaleType         = Enum.ScaleType.Fit
		img.Parent            = card
		corner(img, 6)
	end

	local nameLbl = Instance.new("TextLabel")
	nameLbl.Size                = UDim2.new(1, -12, 0, 18)
	nameLbl.Position            = UDim2.new(0, 6, 0, 132)
	nameLbl.BackgroundTransparency = 1
	nameLbl.Text                = tostring(name or "")
	nameLbl.TextColor3          = theme.TEXT_MAIN
	nameLbl.TextSize            = 13
	nameLbl.Font                = Enum.Font.GothamBold
	nameLbl.TextXAlignment      = Enum.TextXAlignment.Center
	nameLbl.TextTruncate        = Enum.TextTruncate.AtEnd
	nameLbl.Parent              = card

	local applyBtn = Instance.new("TextButton")
	applyBtn.Size              = UDim2.new(1, -12, 0, 30)
	applyBtn.Position          = UDim2.new(0, 6, 1, -36)
	applyBtn.BackgroundColor3  = theme.ACCENT
	applyBtn.BorderSizePixel   = 0
	applyBtn.Text              = "Apply"
	applyBtn.TextColor3        = Color3.fromRGB(255, 255, 255)
	applyBtn.TextSize          = 12
	applyBtn.Font              = Enum.Font.GothamBold
	applyBtn.AutoButtonColor   = false
	applyBtn.Parent            = card
	corner(applyBtn, 5)

	applyBtn.MouseEnter:Connect(function()
		tween(applyBtn, { BackgroundColor3 = theme.ACCENT:Lerp(Color3.new(1,1,1), 0.15) }, TI_FAST)
	end)
	applyBtn.MouseLeave:Connect(function()
		tween(applyBtn, { BackgroundColor3 = theme.ACCENT }, TI_FAST)
	end)
	applyBtn.MouseButton1Click:Connect(function()
		tween(applyBtn, { BackgroundColor3 = theme.ACCENT:Lerp(Color3.new(0,0,0), 0.2) }, TI_FAST)
		task.delay(0.1, function() tween(applyBtn, { BackgroundColor3 = theme.ACCENT }, TI_FAST) end)
		if applyCallback then
			local ok, err = pcall(applyCallback, meshId, textureId, name)
			if not ok then warn("[SpareStack] viewport apply failed:", err) end
		end
	end)

	if tooltip and tooltip ~= "" then attachTooltip(card, tooltip) end

	return card
end

