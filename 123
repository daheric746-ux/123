local PLACEHOLDER_ICON = "rbxasset://textures/ui/GuiImagePlaceholder.png"
local iconCache = {}
local function getIcon(name, library)
	local key = (library or "Material") .. "\0" .. tostring(name)
	local hit = iconCache[key]
	if hit then return hit end
	if not icons then
		iconCache[key] = PLACEHOLDER_ICON
		return PLACEHOLDER_ICON
	end
	local ok, id = pcall(function() return icons:get_icon(name, library or "Material") end)
	local result = (ok and id) and ("rbxassetid://" .. id) or PLACEHOLDER_ICON
	iconCache[key] = result
	return result
end

