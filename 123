		cf.Position         = UDim2.new(0, 10, 0.5, -7)
		cf.BackgroundColor3 = selected[opt] and theme.ACCENT or theme.BG_INPUT
		cf.BorderSizePixel  = 0
		cf.ZIndex           = 23
